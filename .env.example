# YouTube Data API v3 key (required for channel/video listing)
# Create one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_api_key_here

# Max videos to fetch per channel per run (then filtered by lookback); default 50
# YOUTUBE_MAX_VIDEOS_PER_CHANNEL=50

# Only include videos uploaded in the last N days (weekly pipeline); default 7
# YOUTUBE_LOOKBACK_DAYS=7

# OpenAI research scraper: only include items from last N days; default 7
# OPENAI_RESEARCH_LOOKBACK_DAYS=7
